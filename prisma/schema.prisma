generator client {
    provider = "prisma-client-js"
}

datasource db {
    provider = "postgresql"
}

model Livro {
    id                   Int      @id @default(autoincrement())
    titulo               String
    capa                 String
    autor                String
    anoPublicacao        Int
    genero_pt            String
    genero_en            String
    resumo_pt            String   @db.Text
    resumo_en            String   @db.Text
    personagens          String[]
    contextoHistorico_pt String
    contextoHistorico_en String
    analise_pt           String   @db.Text
    analise_en           String   @db.Text

    conteudos Conteudos[]
    simulados Simulados[]

    @@map("livro")
}

model Equipe {
    id           Int     @id @default(autoincrement())
    nome         String
    curso        String
    descricao    String
    descricao_en String
    foto         String?

    @@map("equipe")
}

model Usuario {
    id           Int     @id @default(autoincrement())
    nome         String
    idade        Int
    email        String
    username     String
    senha        String
    descricao    String
    descricao_en String
    foto         String?

    @@map("usuario")
}

model Conteudos {
    id               Int     @id @default(autoincrement())
    idDoLivro        Int
    livro            Livro   @relation(fields: [idDoLivro], references: [id])
    dicaTitulo       String
    dicaTitulo_en    String
    tipo             String
    tipo_en          String
    descricaoDica    String
    descricaoDica_en String
    material         String?

    @@map("conteudos")
}

model Simulados {
    id                 Int    @id @default(autoincrement())
    idLivro            Int
    livro              Livro  @relation(fields: [idLivro], references: [id])
    pergunta           String
    pergunta_en        String
    resopostaErrada    String
    resopostaErrada_en String
    respostaCorreta    String
    respostaCorreta_en String

    @@map("simulados")
}
